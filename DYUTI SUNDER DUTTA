<title>Birthday Surprise 🎉</title>

<!-- Google Font -->
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&display=swap" rel="stylesheet">

<style>
body {
  margin: 0;
  font-family: 'Poppins', sans-serif;
  text-align: center;
  background: radial-gradient(circle, #1a1a2e, #000);
  color: white;
  overflow: hidden;
}

.page { display: none; padding: 20px; }
.active { display: block; }

button {
  background: linear-gradient(45deg, #007bff, #00c6ff);
  color: white;
  padding: 14px;
  margin: 10px;
  border: none;
  border-radius: 12px;
  cursor: pointer;
  width: 80%;
  font-size: 16px;
  box-shadow: 0 0 15px rgba(0,123,255,0.6);
}

button:hover {
  transform: scale(1.05);
}

.balloon {
  font-size: 60px;
  cursor: pointer;
  margin-top: 120px;
  animation: float 3s ease-in-out infinite alternate;
}

@keyframes float {
  from { transform: translateY(0); }
  to { transform: translateY(-30px); }
}

/* Fireworks canvas */
canvas {
  position: fixed;
  top: 0;
  left: 0;
  pointer-events: none;
}

/* Full image page */
.full-img {
  width: 100vw;
  height: 100vh;
  object-fit: contain;
  background: black;
}

input {
  padding: 10px;
  width: 70%;
  border-radius: 10px;
  border: none;
}
</style>
</head>

<body>

